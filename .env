# MoodMix 环境配置文件

# ═══ LLM 配置 ═══
# SiliconFlow API Key - 用于 mood 分析
# 在 https://docs.siliconflow.cn/ 获取你的 API Key
SILICONFLOW_API_KEY=sk-ejffatyebwkzpezanmyyxlpmqbtupnmfdyqbvbhjjdmlkitw
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# ═══ 服务器配置 ═══
NODE_ENV=development

# 前端应用端口
# PORT=3000  # 生产环境由 Render 平台设置

# API 代理服务器端口
PROXY_PORT=3001

# ═══ Webpack 开发服务器配置（用于 npm start） ═══
# 禁用 Host 头检查，允许本地访问（localhost, 127.0.0.1 以及其他 Host）
# 这允许你从不同的 Host 访问开发服务器
HOST=0.0.0.0

# 为了支持 Render.com 等平台的自动 Host 头验证，可以设置 DANGEROUSLY_DISABLE_HOST_CHECK
# 仅在开发环境中使用！
DANGEROUSLY_DISABLE_HOST_CHECK=true

# ═══ 可选项 ═══
# 公共 URL（如果部署在子路径上）
PUBLIC_URL=/

# 浏览器自动打开（开发用）
BROWSER=none
